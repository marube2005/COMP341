<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">

    <display-name>SmartCampus Facility Management System</display-name>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Database initialiser – runs schema.sql on startup       -->
    <!-- Creates the database, tables, and demo seed data        -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <listener>
        <listener-class>com.smartcampus.util.DBInitializer</listener-class>
    </listener>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Authentication filter – protects every URL except public paths -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.smartcampus.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Servlets                                                -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- Login / Logout / Register -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Role dashboards -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/lecturer/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/janitor/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/supervisor/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Facility CRUD -->
    <servlet>
        <servlet-name>FacilityServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.FacilityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FacilityServlet</servlet-name>
        <url-pattern>/facilities</url-pattern>
    </servlet-mapping>

    <!-- Cleaning Task CRUD -->
    <servlet>
        <servlet-name>CleaningTaskServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.CleaningTaskServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CleaningTaskServlet</servlet-name>
        <url-pattern>/cleaning-tasks</url-pattern>
    </servlet-mapping>

    <!-- Admin – User Management -->
    <servlet>
        <servlet-name>UserManagementServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.UserManagementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserManagementServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <!-- Lecturer – Report Submission -->
    <servlet>
        <servlet-name>LecturerReportServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.LecturerReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LecturerReportServlet</servlet-name>
        <url-pattern>/lecturer/report</url-pattern>
    </servlet-mapping>

    <!-- Lecturer – Daily Check-in -->
    <servlet>
        <servlet-name>LecturerCheckinServlet</servlet-name>
        <servlet-class>com.smartcampus.servlet.LecturerCheckinServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LecturerCheckinServlet</servlet-name>
        <url-pattern>/lecturer/checkin</url-pattern>
    </servlet-mapping>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Welcome / default page                                  -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Error pages                                             -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <error-page>
        <error-code>403</error-code>
        <location>/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Session configuration                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>
</web-app>
